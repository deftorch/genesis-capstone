# ==============================================
# Genesis - Environment Variables
# ==============================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control!

# ⚠️  PENTING: Jangan pernah menggunakan prefix NEXT_PUBLIC_ untuk API keys.
#    Prefix tersebut akan mengekspos key ke browser dan bisa dicuri siapa saja.

# ================================================================
# AI PROVIDER API KEYS — SERVER SIDE ONLY (jangan pakai NEXT_PUBLIC_)
# Nilai ini TIDAK dikirim ke browser.
# ================================================================

# Google Gemini API Key (WAJIB)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: multiple keys for rotation (numbered sequentially)
# GEMINI_API_KEY_1=
# GEMINI_API_KEY_2=

# Optional AI providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Google Cloud (optional, for advanced features)
# GOOGLE_CLOUD_API_KEY=
# GOOGLE_CLOUD_PROJECT_ID=

# ----------------------------------------------
# App Configuration
# ----------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_NAME="Genesis"
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ----------------------------------------------
# Optional: Supabase (for image storage)
# ----------------------------------------------
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------------
# Image Cleanup Authorization
# ----------------------------------------------
# Generate with: openssl rand -hex 32
CRON_TOKEN=your_cron_token_here

# ----------------------------------------------
# Optional: Redis (for rate limiting in multi-instance deployment)
# ----------------------------------------------
# REDIS_URL=redis://localhost:6379
