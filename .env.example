# Base URL (production)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ================================
# API KEYS - DO NOT COMMIT TO GIT
# ================================

# Thumbsnap Image Upload API
# Get from: https://thumbsnap.com/api
THUMBSNAP_API_KEY=your-thumbsnap-api-key-here

# Google Gemini API Key
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# OpenRouter API Key
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# WAJIB diisi sebelum deploy ke production
# Generate dengan: openssl rand -hex 32
CRON_TOKEN=your-secure-random-token-here
